DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/amittech_blog?schema=public"
NEXT_PUBLIC_SITE_URL="https://amittech.in"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
SESSION_COOKIE_NAME="amittech_session"
SESSION_DAYS="30"
SUPER_ADMIN_EMAILS="you@example.com"

# Optional server-side analytics providers
ANALYTICS_PROVIDER=""
GA4_MEASUREMENT_ID=""
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""
GA4_API_SECRET=""
MIXPANEL_TOKEN=""
SEGMENT_WRITE_KEY=""

# Optional GlitchTip monitoring
GLITCHTIP_DSN=""
NEXT_PUBLIC_GLITCHTIP_DSN=""
GLITCHTIP_ENVIRONMENT="production"
NEXT_PUBLIC_GLITCHTIP_ENVIRONMENT="production"
GLITCHTIP_TRACES_SAMPLE_RATE="0.1"
NEXT_PUBLIC_GLITCHTIP_TRACES_SAMPLE_RATE="0.1"
GLITCHTIP_SECURITY_REPORT_URI=""

# Optional Sentry Cloud source map upload only.
# Not required for GlitchTip event reporting.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Optional Cloudinary media storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
